# Deployment settings for compose-deploy.yml. Copy to `.env` and edit;
# only RAUTHY_PUB_URL is mandatory. Full guide: docs/deployment.md.

# ---- domains ---------------------------------------------------------
# Public hostname of the identity provider as proxied by NPM (no scheme).
RAUTHY_PUB_URL=auth.example.com

# ---- rauthy ----------------------------------------------------------
# First-boot admin bootstrap; comment both out to get admin@localhost
# with a random password in the logs instead. Change it after login.
RAUTHY_ADMIN_EMAIL=you@example.com
RAUTHY_ADMIN_PASSWORD=change-me-on-first-login
# CIDRs your reverse proxy connects from (comma list). Default: all
# private ranges - tighten when you know the proxy's address.
#RAUTHY_TRUSTED_PROXIES=192.168.1.0/24
#RAUTHY_PORT=8080
#RAUTHY_LOG_LEVEL=info

# ---- parcello --------------------------------------------------------
# Image tag: latest, or pin a release tag (vX.Y.Z) for reproducibility.
#PARCELLO_TAG=latest
#PARCELLO_PORT=7878
#PARCELLO_LOG=info
# Room defaults, host-editable per room in the lobby (ADR-0015). 0 = off.
#PARCELLO_TURN_TIMEOUT=25
#PARCELLO_GAME_TIMEOUT=3600
# Rauthy client id the identity tokens must be issued for.
#PARCELLO_IDENTITY_AUDIENCE=parcello
# JWKS to trust (comma list = redundant instances of the same issuer).
#PARCELLO_IDENTITY_URLS=http://rauthy:8080/auth/v1/oidc/certs
